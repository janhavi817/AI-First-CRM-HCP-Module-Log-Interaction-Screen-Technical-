# Groq API Key (Request an API Key from https://console.groq.com)
# Example: GROQ_API_KEY=gsk_...
GROQ_API_KEY=

# Database Connection (Default is local SQLite database)
# To use MySQL or PostgreSQL, uncomment and modify the appropriate connection string below:
# DATABASE_URL=mysql+pymysql://username:password@localhost/db_name
# DATABASE_URL=postgresql://username:password@localhost/db_name
DATABASE_URL=sqlite:///./crm_hcp.db
